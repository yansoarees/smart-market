generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model pedido {
  id             Int      @id @default(autoincrement())
  nomeCliente    String
  telefone       String?
  total          Float
  itens          String   @db.Text
  endereco       String?  @db.Text
  formaEntrega   String?
  formaPagamento String?
  status         String?  @default("Pendente")
  data_criacao   DateTime @default(now())
}

model produto {
  id             Int      @id @default(autoincrement())
  nome           String
  preco          Float
  categoria      String?
  tipo           String?  @default("und")
  estoque        Float?   @default(100)
  ativo          Int?     @default(1)
  promocao       Boolean? @default(false)
  preco_promocao Decimal? @db.Decimal(10, 2)
  qtd_promocao   Int?     @default(1)
  imagem         String?  @db.Text
  variacoes      String?  @db.Text
}

model usuario {
  id    Int     @id @default(autoincrement())
  nome  String
  email String  @unique(map: "Usuario_email_key")
  senha String
  papel String? @default("USER")
}
